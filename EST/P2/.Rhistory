media_recortada <- function(x, trim = 0.2) {
n <- length(x)
k <- round(trim * n)
# Validación de seguridad
if (k < 0 | k >= n/2) stop("Valor de 'trim' incorrecto")
# 1. Ordenamos el vector
x_sort <- sort(x)
# 2. Identificamos los valores de reemplazo (el menor y el mayor de los restantes)
val_min <- x_sort[k + 1]
val_max <- x_sort[n - k]
# 3. Reemplazamos los extremos (solo si k > 0)
if (k > 0) {
x_sort[1:k] <- val_min           # Reemplaza los primeros k elementos
x_sort[(n - k + 1):n] <- val_max # Reemplaza los últimos k elementos
}
# 4. Calculamos la media del vector modificado
return(mean(x_sort))
}
# Prueba con el dataset 'precip' (usado en tu ejemplo)
media_recortada(precip)
media_truncada <- function(x, trim = 0.2) {
n <- length(x)
k <- round(trim*n)
if ( k < 0 | k >= n/2 ) stop("Valor de 'trim' incorrecto")
x <- sort(x)
min = x[k +1 ]
max = x[n - k]
print(min)
print(max)
x[1:k] = min
x[(n- k) :n] = max
return(mean(x))
}
media_truncada(precip)
